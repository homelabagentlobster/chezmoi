{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "command -v atuin >/dev/null 2>&1 && atuin hook codex || true",
            "type": "command"
          }
        ],
        "matcher": "^Bash$"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "command -v atuin >/dev/null 2>&1 && atuin hook codex || true",
            "type": "command"
          }
        ],
        "matcher": "^Bash$"
      }
    ]
  }
}
